# App settings
PROJECT_NAME=Ambience AI
PROJECT_VERSION=1.5.0
APP_ENV=development
SECRET_KEY=ambience_local_backend_secret_change_before_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql://admin:ambience_local_db_pw@db_vector:5432/ambience_knowledge
RAG_SERVICE_URL=http://rag_service:8001
RAG_INTERNAL_API_KEY=ambience_local_rag_internal_key_change_before_production
RAG_REQUEST_TIMEOUT_SECONDS=120
UPLOAD_DIR=/app/uploads
AUTH_BOOTSTRAP_DEMO_USERS=true
COOKIE_SECURE=false
FRONTEND_BASE_URL=http://localhost:3000

# Email verification / password reset
NEW_USERS_REQUIRE_EMAIL_VERIFICATION=true
ALLOW_LEGACY_UNVERIFIED_LOGIN=false
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
EMAIL_VERIFICATION_TOKEN_PEPPER=ambience_local_email_verification_pepper_change_before_production
RESEND_VERIFICATION_RATE_LIMIT_WINDOW_SECONDS=900
RESEND_VERIFICATION_RATE_LIMIT_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_EMAIL_LOG_ONLY=false
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=900
FORGOT_PASSWORD_RATE_LIMIT_MAX_ATTEMPTS=5
PASSWORD_RESET_EMAIL_LOG_ONLY=false
PASSWORD_RESET_TOKEN_PEPPER=ambience_local_password_reset_pepper_change_before_production

# SMTP (local default uses Mailpit from root compose)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@localhost
SMTP_USE_TLS=false

# Demo users
DEMO_GP_PASSWORD=Password123!
DEMO_SPECIALIST_PASSWORD=Password123!
DEMO_ADMIN_PASSWORD=Password123!

# Backend cache settings
CACHE_ENABLED=true
REDIS_URL=redis://redis:6379/0
# For local development without Docker, use:
# REDIS_URL=redis://localhost:6379/0
CACHE_KEY_PREFIX=cache
CACHE_CHAT_LIST_TTL=30
CACHE_CHAT_DETAIL_TTL=60
CACHE_PROFILE_TTL=300
CACHE_SPECIALIST_LIST_TTL=30
CACHE_ADMIN_STATS_TTL=30
CACHE_ADMIN_CHAT_TTL=30
CACHE_ADMIN_AUDIT_LOG_TTL=15
CACHE_NOTIFICATION_TTL=30

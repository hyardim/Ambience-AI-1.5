# App settings
PROJECT_NAME=Ambience AI
PROJECT_VERSION=1.5.0
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql://admin:CHANGE_ME_DB_PASSWORD@db_vector:5432/ambience_knowledge
RAG_SERVICE_URL=http://rag_service:8001
RAG_REQUEST_TIMEOUT_SECONDS=120
UPLOAD_DIR=/app/uploads
AUTH_BOOTSTRAP_DEMO_USERS=true
COOKIE_SECURE=false

# Backend cache settings
CACHE_ENABLED=true
REDIS_URL=redis://redis:6379/0
# For local development without Docker, use:
# REDIS_URL=redis://localhost:6379/0
CACHE_KEY_PREFIX=cache
CACHE_CHAT_LIST_TTL=30
CACHE_CHAT_DETAIL_TTL=60
CACHE_PROFILE_TTL=300

# ---------- Database (Docker: ambience_db) ----------
# Connects to pgvector Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=team20_password
POSTGRES_DB=ambience_knowledge
DATABASE_URL=postgresql://admin:team20_password@localhost:5432/ambience_knowledge

# ---------- Data location ----------
# Root directory where PDFs live (rag_data/<specialty>/<publisher>/*.pdf)
RAG_DATA_DIR=rag_data

# ---------- Embeddings ----------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ---------- Chunking ----------
CHUNK_SIZE=450
CHUNK_OVERLAP=100

# ---------- Vector index (HNSW) ----------
HNSW_M=16
HNSW_EF_CONSTRUCTION=64

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FILE=logs/rag.log

# ---------- Local model (Ollama) ----------
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=thewindmom/llama3-med42-8b
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_TIMEOUT_SECONDS=60

# ---------- Cloud model (RunPod vLLM) ----------
CLOUD_LLM_BASE_URL=https://<YOUR_POD_ID>-8000.proxy.runpod.net/v1
CLOUD_LLM_MODEL=m42-health/Llama3-Med42-70B
CLOUD_LLM_API_KEY=<YOUR_RUNPOD_POD_TOKEN>
CLOUD_LLM_TIMEOUT_SECONDS=120

# ---------- Heuristic routing ----------
# If query complexity score >= LLM_ROUTE_THRESHOLD, route to cloud first.
LLM_ROUTE_THRESHOLD=0.65
# Revisions (/revise) go cloud-first when true.
ROUTE_REVISIONS_TO_CLOUD=true

# ---------- Database (Docker: ambience_db) ----------
# Connects to pgvector Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_postgres_db
DATABASE_URL=postgresql://your_postgres_user:your_postgres_password@localhost:5432/your_postgres_db

# ---------- Data location ----------
# Root directory where source documents live
RAG_DATA_DIR=data/raw

# ---------- Embeddings ----------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ---------- Chunking ----------
CHUNK_SIZE=450
CHUNK_OVERLAP=100

# ---------- Vector index (HNSW) ----------
HNSW_M=16
HNSW_EF_CONSTRUCTION=64

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FILE=logs/rag.log

# ---------- Local model (optional fallback) ----------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=thewindmom/llama3-med42-8b
OLLAMA_MAX_TOKENS=512
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=thewindmom/llama3-med42-8b
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_MAX_TOKENS=512
LOCAL_LLM_TIMEOUT_SECONDS=60

# ---------- Cloud model (RunPod 70B) ----------
# Change these three values when you switch to a new RunPod pod.
RUNPOD_POD_ID=YOUR_RUNPOD_POD_ID
RUNPOD_PORT=8000
RUNPOD_API_KEY=YOUR_RUNPOD_API_KEY

# Optional overrides. Leave CLOUD_* blank to auto-build from RUNPOD_* above.
LLM_BASE_URL=
LLM_MODEL=m42-health/Llama3-Med42-70B
LLM_API_KEY=
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=120
CLOUD_LLM_BASE_URL=
CLOUD_LLM_MODEL=m42-health/Llama3-Med42-70B
CLOUD_LLM_API_KEY=
CLOUD_LLM_MAX_TOKENS=1024
CLOUD_LLM_TEMPERATURE=0.1
CLOUD_LLM_TIMEOUT_SECONDS=120

# ---------- Routing ----------
LLM_ROUTE_THRESHOLD=0.65
ROUTE_REVISIONS_TO_CLOUD=true
FORCE_CLOUD_LLM=false

# ---------- Retry queue ----------
REDIS_URL=redis://localhost:6379/0
RETRY_ENABLED=true
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=10
RETRY_BACKOFF_MULTIPLIER=2
RETRY_JOB_TTL_SECONDS=86400

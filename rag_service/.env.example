# ---------- Database ----------
# Individual POSTGRES_* fields are used to build the default connection string.
# DATABASE_URL can be used as an explicit override when needed.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ambience_knowledge
DATABASE_URL=

# ---------- Data location ----------
# Root directory where source documents live
RAG_DATA_DIR=data/raw

# ---------- Embeddings ----------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ---------- Chunking ----------
CHUNK_SIZE=450
CHUNK_OVERLAP=100

# ---------- Vector index (HNSW) ----------
HNSW_M=16
HNSW_EF_CONSTRUCTION=64

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FILE=logs/rag.log

# ---------- Local model ----------
# The service defaults to Ollama for the local provider.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=thewindmom/llama3-med42-8b
OLLAMA_MAX_TOKENS=1024
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=thewindmom/llama3-med42-8b
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_MAX_TOKENS=1024
LOCAL_LLM_TIMEOUT_SECONDS=60
# Optional Docker-only override for containers talking to a host Ollama instance.
DOCKER_OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---------- Cloud model (optional) ----------
# Change the RUNPOD_* values when you switch to a new RunPod pod.
RUNPOD_POD_ID=YOUR_RUNPOD_POD_ID
RUNPOD_PORT=8000
RUNPOD_API_KEY=YOUR_RUNPOD_API_KEY

# Optional overrides. Leave CLOUD_* blank to auto-build from RUNPOD_* above.
LLM_BASE_URL=
LLM_MODEL=m42-health/Llama3-Med42-70B
LLM_API_KEY=
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=120
CLOUD_LLM_BASE_URL=
CLOUD_LLM_MODEL=m42-health/Llama3-Med42-70B
CLOUD_LLM_API_KEY=
CLOUD_LLM_MAX_TOKENS=1024
CLOUD_LLM_TEMPERATURE=0.1
CLOUD_LLM_TIMEOUT_SECONDS=120

# ---------- Routing ----------
LLM_ROUTE_THRESHOLD=0.65
ROUTE_REVISIONS_TO_CLOUD=true
FORCE_CLOUD_LLM=false

# ---------- Retrieval canonicalization (feature-flagged) ----------
RETRIEVAL_CANONICALIZATION_ENABLED=false
# Comma-separated specialties where canonical retrieval rewrite is allowed.
RETRIEVAL_CANONICALIZATION_SPECIALTIES=rheumatology

# ---------- Retry queue ----------
REDIS_URL=redis://localhost:6379/0
RAG_INTERNAL_API_KEY=change_me
RETRY_ENABLED=true
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=10
RETRY_BACKOFF_MULTIPLIER=2
RETRY_JOB_TTL_SECONDS=86400

# ---------- Alerting (optional, local-friendly) ----------
# If set, provider fallback events will also be sent as POST JSON payloads.
# You can point this to any local/internal webhook receiver.
LLM_FALLBACK_ALERT_WEBHOOK_URL=
LLM_FALLBACK_ALERT_TIMEOUT_SECONDS=2.0

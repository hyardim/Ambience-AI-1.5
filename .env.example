# Root Docker Compose environment
#
# Copy this file to `.env` at the repo root before running:
#   cp .env.example .env

# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=ambience_knowledge

# Cloud LLM
CLOUD_LLM_BASE_URL=https://your-openai-compatible-endpoint.example/v1
CLOUD_LLM_MODEL=m42-health/Llama3-Med42-70B
CLOUD_LLM_API_KEY=CHANGE_ME_CLOUD_API_KEY

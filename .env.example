# =============================================================================
# Ambience AI — Environment Variables
# Copy this file to .env and fill in all values marked REQUIRED before deploying
# Never commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=REQUIRED_change_this_strong_password
POSTGRES_DB=ambience_knowledge

# -----------------------------------------------------------------------------
# Backend — JWT / Security
# REQUIRED: Set to a long random string (e.g. openssl rand -hex 32)
# This signs all JWT tokens — changing it invalidates all active sessions
# -----------------------------------------------------------------------------
SECRET_KEY=REQUIRED_replace_with_random_secret

# -----------------------------------------------------------------------------
# Backend — Email verification & password reset tokens
# REQUIRED: Set to a long random string (can match SECRET_KEY or be separate)
# -----------------------------------------------------------------------------
EMAIL_VERIFICATION_TOKEN_PEPPER=REQUIRED_replace_with_random_secret
PASSWORD_RESET_TOKEN_PEPPER=REQUIRED_replace_with_random_secret

# -----------------------------------------------------------------------------
# SMTP — Outbound email (verification, password reset)
# -----------------------------------------------------------------------------
# Local Docker default uses Mailpit on the internal network.
# For production, set SMTP_HOST/PORT/USE_TLS/USERNAME/PASSWORD to your provider.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@localhost

# Set to true to skip real email sending and log tokens to console instead (dev only)
EMAIL_VERIFICATION_EMAIL_LOG_ONLY=false
PASSWORD_RESET_EMAIL_LOG_ONLY=false

# -----------------------------------------------------------------------------
# Frontend
# REQUIRED: Set to the public URL of the frontend (used in email links)
# -----------------------------------------------------------------------------
FRONTEND_BASE_URL=https://your-domain.nhs.uk

# REQUIRED: Set to a long random string for encrypting browser localStorage
# e.g. openssl rand -hex 32
VITE_STORAGE_KEY=REQUIRED_replace_with_random_secret

# -----------------------------------------------------------------------------
# RAG Service — LLM
# Local model (Ollama) — runs inside Docker, no key needed
# Cloud model (RunPod / HuggingFace) — used for complex queries
# -----------------------------------------------------------------------------
RAG_INTERNAL_API_KEY=REQUIRED_replace_with_random_secret
CLOUD_LLM_BASE_URL=REQUIRED_your_runpod_endpoint/v1
CLOUD_LLM_API_KEY=REQUIRED_your_huggingface_or_runpod_api_key
CLOUD_LLM_MODEL=m42-health/Llama3-Med42-70B
OLLAMA_MODEL=thewindmom/llama3-med42-8b
LOCAL_LLM_MODEL=thewindmom/llama3-med42-8b

# Confidence threshold below which queries are routed to cloud model (0.0-1.0)
LLM_ROUTE_THRESHOLD=0.65

# -----------------------------------------------------------------------------
# Nginx TLS bootstrap (production profile)
# -----------------------------------------------------------------------------
# If true and cert files are missing, nginx auto-generates a local self-signed cert.
# Set to false in strict production and provide real cert files in nginx/certs/.
NGINX_GENERATE_SELF_SIGNED=true
NGINX_SELF_SIGNED_DAYS=30
NGINX_SELF_SIGNED_SUBJECT=/CN=localhost

# -----------------------------------------------------------------------------
# Auth behaviour
# -----------------------------------------------------------------------------
NEW_USERS_REQUIRE_EMAIL_VERIFICATION=true
# Set to true only if you need legacy users (pre-verification) to be able to log in
ALLOW_LEGACY_UNVERIFIED_LOGIN=false

# Rate limiting
FORGOT_PASSWORD_RATE_LIMIT_MAX_ATTEMPTS=5
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=900
RESEND_VERIFICATION_RATE_LIMIT_MAX_ATTEMPTS=5
RESEND_VERIFICATION_RATE_LIMIT_WINDOW_SECONDS=900

# -----------------------------------------------------------------------------
# Cookie / session settings
# -----------------------------------------------------------------------------
# Must be false for local HTTP development; true only behind HTTPS in production
COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Demo user seeding (development / test only)
# -----------------------------------------------------------------------------
# Set to true to auto-create GP, Specialist and Admin accounts on startup
AUTH_BOOTSTRAP_DEMO_USERS=true
DEMO_GP_PASSWORD=Password123!
DEMO_SPECIALIST_PASSWORD=Password123!
DEMO_ADMIN_PASSWORD=Password123!
